# ======================================================
#   J.A.R.V.I.S. MARK III - NEURAL CONFIGURATION
# ======================================================

# --- USER IDENTITY ---
Username=User
Assistantname=J.A.R.V.I.S
InputLanguage=en
AssistantVoice=en-GB-RyanNeural

# --- CORE BRAIN KEYS (REQUIRED) ---
# Get it at: https://console.groq.com/keys
GroqAPIKey=PASTE_GROQ_KEY_HERE

# Get it at: https://dashboard.cohere.com/api-keys
CohereAPIKey=PASTE_COHERE_KEY_HERE

# Get it at: https://bytez.com
BytezAPIKey=PASTE_BYTEZ_KEY_HERE

# Get it at: https://huggingface.co/settings/tokens
HuggingFaceAPIKey=PASTE_HUGGINGFACE_KEY_HERE

# Get it at: https://platform.openai.com/api-keys
OpenAI_API_Key=PASTE_OPENAI_KEY_HERE

# Get it at: https://console.picovoice.ai
PICOVOICE_API_KEY=PASTE_PICOVOICE_KEY_HERE

# Get it at: https://www.pushbullet.com/#settings
PUSHBULLET_API_KEY=PASTE_PUSHBULLET_KEY_HERE

# --- OPTIONAL / BACKUP ENGINES ---
# Get it at: https://aistudio.google.com/app/apikey
GeminiAPIKey=PASTE_GEMINI_KEY_HERE

# Get it at: https://pollinations.ai
PollinationsAPIKey=PASTE_POLLINATIONS_KEY_HERE

# Get it at: https://developer.wolframalpha.com
WolframAPIKey=PASTE_WOLFRAM_KEY_HERE

# Get it at: https://home.openweathermap.org/api_keys
WeatherAPIKey=PASTE_OPENWEATHER_KEY_HERE

# Get it at: https://newsapi.org/register
NewsAPIKey=PASTE_NEWSAPI_KEY_HERE

# --- SPOTIFY SENTRY MODE ---
# Create App at: https://developer.spotify.com/dashboard
# Set Redirect URI to: http://127.0.0.1:8080/
SPOTIFY_CLIENT_ID=PASTE_SPOTIFY_ID_HERE
SPOTIFY_CLIENT_SECRET=PASTE_SPOTIFY_SECRET_HERE
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/

# --- EMAIL SENTRY (GMAIL) ---
# Requires a 16-letter App Password (NOT your login password)
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=PASTE_16_LETTER_APP_PASSWORD_HERE

# --- SMART HOME (DAWLANCE/ANDROID TV) ---
# Find this in TV Settings > Network. Ensure ADB Debugging is ON in Developer Options.
TV_IP=192.168.X.XX